# EditorConfig ayuda a mantener el MISMO estilo de archivo
# en cualquier editor y en cualquier sistema operativo (Linux, Windows, Mac).
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf          # Siempre saltos de línea estilo Unix (evita el error \r en Linux)
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,json}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
